# ========================
# CONFIGURACIÓN DEL SERVIDOR
# ========================
PORT=3000
NODE_ENV=development

# ========================
# SEGURIDAD - REQUERIDO
# ========================
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=tu-secret-session-aqui-minimo-32-caracteres
JWT_SECRET=tu-secret-jwt-aqui-minimo-32-caracteres

# ========================
# BASE DE DATOS
# ========================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=db_galugas_web

# ========================
# AUTENTICACIÓN JWT
# ========================
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ========================
# RATE LIMITING
# ========================
# Ventana de tiempo en milisegundos (15 min = 900000)
RATE_LIMIT_WINDOW_MS=900000
# Máximo de solicitudes por ventana
RATE_LIMIT_MAX_REQUESTS=100
